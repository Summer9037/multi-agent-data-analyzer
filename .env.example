# === Anthropic Claude API ===
ANTHROPIC_API_KEY=sk-ant-your-key-here

# 可选：第三方代理 / 自建网关（国内用户常见）。留空则用 Anthropic 官方端点。
# 注意：proxy 必须**支持 Anthropic Messages API 原生协议**（接受 SDK 直连），
# 不要用只面向 Claude Code 客户端的反代（会触发"非标准客户端"检测被拒）。
# ANTHROPIC_BASE_URL=https://www.packyapi.com

# 模型 ID（按 Agent 角色分配）。可降本：把 Planner/Reporter 也换成 Sonnet。
ANTHROPIC_MODEL_PLANNER=claude-opus-4-7
ANTHROPIC_MODEL_REPORTER=claude-opus-4-7
ANTHROPIC_MODEL_WORKER=claude-sonnet-4-6


# === PostgreSQL ===
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auto_analysis


# === 数据 & 输出路径 ===
# 原始 3 个 CSV（ad_feature / raw_sample / user_profile）所在目录
# Windows 路径用正斜杠或双反斜杠；不要中文路径，避免 pandas read_csv 编码问题
RAW_DATA_DIR=./data
OUTPUT_DIR=./outputs


# === 运行时参数 ===
# raw_sample 分层采样大小（保留 clk 正负样本原始比例）
RAW_SAMPLE_SIZE=300000

# Agent 单步循环最大迭代次数（防死循环）
AGENT_MAX_ITERATIONS=10
